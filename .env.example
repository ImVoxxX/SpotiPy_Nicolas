SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:5000/callback
FLASK_SECRET_KEY=change_me_to_a_random_string

# Instructions:
# 1. Replace 'your_client_id_here' with your actual Spotify Client ID.
# 2. Replace 'your_client_secret_here' with your actual Spotify Client Secret.
# 3. Optionally, change the FLASK_SECRET_KEY to a random string for better security.
# 4. Save this file as '.env' in the root directory of your project.
